<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.example</groupId>
  <artifactId>java-code-chunker</artifactId>
  <name>Java Code Chunker for LM-Studio</name>
  <version>1.0-SNAPSHOT</version>
  <description>Hierarchical Java code chunking and indexing tool using JavaParser with Symbol Solver.
        Produces method-level chunks with call graph edges for graph-aware LLM retrieval.</description>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-resources-plugin</artifactId>
        <version>3.0.2</version>
      </plugin>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <source>17</source>
          <target>17</target>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>com.smolnij.chunker.ChunkerMain</mainClass>
                </transformer>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.target>17</maven.compiler.target>
    <javaparser.version>3.26.4</javaparser.version>
    <gson.version>2.12.1</gson.version>
    <maven.compiler.source>17</maven.compiler.source>
    <jtokkit.version>1.1.0</jtokkit.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <neo4j.driver.version>5.27.0</neo4j.driver.version>
    <langchain4j.version>1.0.0-beta1</langchain4j.version>
  </properties>
</project>
