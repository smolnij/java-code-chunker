{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "llm_response",
  "description": "Union of the four per-role response schemas, discriminated by response_type. Mirrors PromptBuilder's refactorSchema / analysisSchema / safetyCheckSchema / safetyVerdictSchema. Prefer the per-role files (refactor_response, analysis_response, safety_check_response, safety_verdict) when you can select a schema per request; use this union only as a sticky server-side fallback.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["response_type", "code_blocks", "explanation", "breaking_changes", "missing_references"],
      "properties": {
        "response_type": { "type": "string", "enum": ["refactor"] },
        "code_blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["class", "method", "code"],
            "properties": {
              "class": { "type": "string" },
              "method": { "type": "string" },
              "code": { "type": "string" }
            }
          }
        },
        "explanation": { "type": "string" },
        "breaking_changes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_references": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["response_type", "dependencies", "impact", "missing_references"],
      "properties": {
        "response_type": { "type": "string", "enum": ["analysis"] },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "impact": { "type": "string" },
        "missing_references": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["response_type", "explanation", "breaking_changes"],
      "properties": {
        "response_type": { "type": "string", "enum": ["safety_check"] },
        "explanation": { "type": "string" },
        "breaking_changes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["response_type", "confidence", "verdict", "risks", "needs", "feedback"],
      "properties": {
        "response_type": { "type": "string", "enum": ["safety_verdict"] },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "verdict": {
          "type": "string",
          "enum": ["SAFE", "UNSAFE"]
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["description", "severity", "mitigation"],
            "properties": {
              "description": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["HIGH", "MEDIUM", "LOW"]
              },
              "mitigation": { "type": "string" }
            }
          }
        },
        "needs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "feedback": { "type": "string" }
      }
    }
  ]
}
