{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "safety_verdict",
  "type": "object",
  "additionalProperties": false,
  "required": ["confidence", "verdict", "risks", "needs", "feedback"],
  "properties": {
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "verdict": {
      "type": "string",
      "enum": ["SAFE", "UNSAFE"]
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "severity", "mitigation"],
        "properties": {
          "description": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "mitigation": { "type": "string" }
        }
      }
    },
    "needs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "feedback": { "type": "string" }
  }
}
